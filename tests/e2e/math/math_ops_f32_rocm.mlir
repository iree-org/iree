func.func @test_acos_f32() -> () {
  %input = util.unfoldable_constant dense<[-1.0, -0.75, -0.5, -0.25, 0.0, 0.25, 0.5, 0.75, 1.0]> : tensor<9xf32>
  %result_empty = tensor.empty() : tensor<9xf32>
  %result = linalg.generic {indexing_maps = [
      affine_map<(d0) -> (d0)>,
      affine_map<(d0) -> (d0)>
    ], iterator_types = ["parallel"]}
    ins(%input : tensor<9xf32>) outs(%result_empty : tensor<9xf32>) {
  ^bb0(%in: f32, %out: f32):
    %result = math.acos %in : f32
    linalg.yield %result : f32
  } -> tensor<9xf32>
  check.expect_almost_eq_const(%result,
