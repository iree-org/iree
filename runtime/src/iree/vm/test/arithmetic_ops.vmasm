vm.export @test_rem_i32s
vm.func @test_rem_i32s() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 -1  // 0xFFFFFFFF
  %i2 = vm.const.i32 -2  // 0xFFFFFFFE
  %i3 = vm.const.i32 -3  // 0xFFFFFFFD
  %i2 = vm.rem.i32.s %i3, %i2
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "-3%-2=-1"
}

