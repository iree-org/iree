vm.module @arithmetic_ops version 0
vm.type i32

vm.export @test_add_i32
vm.func @test_add_i32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 2  // 0x00000002
  %i2 = vm.const.i32 1  // 0x00000001
  %i2 = vm.add.i32 %i2, %i2
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "1+1=2"
}

vm.export @test_sub_i32
vm.func @test_sub_i32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2 = vm.const.i32 2  // 0x00000002
  %i3 = vm.const.i32 3  // 0x00000003
  %i2 = vm.sub.i32 %i3, %i2
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "3-2=1"
}

vm.export @test_mul_i32
vm.func @test_mul_i32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 4  // 0x00000004
  %i2 = vm.const.i32 2  // 0x00000002
  %i2 = vm.mul.i32 %i2, %i2
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "2*2=4"
}

vm.export @test_div_i32s
vm.func @test_div_i32s() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 -2  // 0xFFFFFFFE
  %i2 = vm.const.i32 4  // 0x00000004
  %i2 = vm.div.i32.s %i2, %i1
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "4/-2=-2"
}

