vm.export @test_not_i32
vm.func @test_not_i32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 -1  // 0xFFFFFFFF
  %i2 = vm.const.i32.zero
  %i2 = vm.not.i32 %i2
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "~0=-1"
}

vm.export @test_and_i32
vm.func @test_and_i32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
