vm.export @test_fma_i32
vm.func @test_fma_i32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 11  // 0x0000000B
  %i2 = vm.const.i32 5  // 0x00000005
  %i3 = vm.const.i32 3  // 0x00000003
  %i4 = vm.const.i32 2  // 0x00000002
  %i2 = vm.fma.i32 %i4, %i3, %i2
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "2*3+5=11"
}

vm.export @test_abs_i32
vm.func @test_abs_i32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2 = vm.const.i32 -1  // 0xFFFFFFFF
  %i2 = vm.abs.i32 %i2
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "abs(-1)=1"
}

vm.export @test_min_i32s
vm.func @test_min_i32s() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 2  // 0x00000002
  %i2 = vm.const.i32 -3  // 0xFFFFFFFD
  %i1 = vm.min.i32.s %i2, %i1
  %i2 = vm.cmp.ne.i32 %i1, %i2
  vm.cond_br %i2, ^bb2(), ^bb1()
^bb1:
