vm.module @comparison_ops version 0
vm.type i32

vm.export @test_cmp_lt_s_0
vm.func @test_cmp_lt_s_0() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 -2  // 0xFFFFFFFE
  %i2 = vm.const.i32 2  // 0x00000002
  %i1 = vm.cmp.lt.i32.s %i2, %i1
  %i1 = vm.cmp.nz.i32 %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "2 < -2"
}

vm.export @test_cmp_lt_s_1
vm.func @test_cmp_lt_s_1() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2 = vm.const.i32 2  // 0x00000002
  %i3 = vm.const.i32 -2  // 0xFFFFFFFE
  %i2 = vm.cmp.lt.i32.s %i3, %i2
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "-2 < 2"
}

vm.export @test_cmp_lt_s_2
vm.func @test_cmp_lt_s_2() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2 = vm.const.i32 2  // 0x00000002
  %i3 = vm.const.i32 -1  // 0xFFFFFFFF
  %i2 = vm.cmp.lt.i32.s %i3, %i2
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "4294967295 (UINT_MAX) < 2"
}

vm.export @test_cmp_lt_u_0
vm.func @test_cmp_lt_u_0() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2 = vm.const.i32 -2  // 0xFFFFFFFE
  %i3 = vm.const.i32 2  // 0x00000002
  %i2 = vm.cmp.lt.i32.u %i3, %i2
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "2 < -2 (as unsigned)"
}

