^bb0:
  vm.return %R1, %R2, %R0
}

vm.export @test_branch_arg_cycling
vm.func @test_branch_arg_cycling() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2 = vm.const.i32.zero
