  vm.cond_br %i2, ^bb4(), ^bb1()
^bb1:
  %i2 = vm.cmp.eq.ref %r4, %r2
  vm.discard.refs %r4, %r2
  %i2 = vm.xor.i32 %i2, %i1
  vm.cond_br %i2, ^bb5(), ^bb2()
^bb2:
  %i2 = vm.cmp.eq.ref %r5, %r0
  vm.discard.refs %r5, %r0
  %i1 = vm.xor.i32 %i2, %i1
  vm.cond_br %i1, ^bb6(), ^bb3()
^bb3:
  vm.return
^bb4:
  vm.discard.refs %r0, %r2, %r4, %r5
  vm.br ^bb6()
^bb5:
  vm.discard.refs %r0, %r5
  vm.br ^bb6()
^bb6:
  vm.fail %i0, ""
}

