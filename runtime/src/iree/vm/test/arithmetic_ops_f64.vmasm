vm.export @test_add_f64
vm.func @test_add_f64() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i2:3 = vm.const.f64 3
  %i4:5 = vm.const.f64 1.5
  %i4:5 = vm.add.f64 %i4:5, %i4:5
  %i1 = vm.cmp.ne.f64.o %i4:5, %i2:3
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
