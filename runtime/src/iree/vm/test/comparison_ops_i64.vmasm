vm.module @comparison_ops_i64 version 0
vm.type i32
vm.type i64

vm.export @test_cmp_lt_s_0_i64
vm.func @test_cmp_lt_s_0_i64() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i2:3 = vm.const.i64 -4294967295  // 0xFFFFFFFF00000001
  %i4:5 = vm.const.i64 4294967295  // 0x00000000FFFFFFFF
  %i1 = vm.cmp.lt.i64.s %i4:5, %i2:3
  %i1 = vm.cmp.nz.i32 %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "4294967295 (UINT_MAX) < -4294967295 (UINT_MAX)"
}

vm.export @test_cmp_lt_s_1_i64
vm.func @test_cmp_lt_s_1_i64() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2:3 = vm.const.i64 4294967295  // 0x00000000FFFFFFFF
  %i4:5 = vm.const.i64 -4294967295  // 0xFFFFFFFF00000001
  %i6 = vm.cmp.lt.i64.s %i4:5, %i2:3
  %i1 = vm.cmp.ne.i32 %i6, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "-4294967295 (UINT_MAX) < 4294967295 (UINT_MAX)"
}

vm.export @test_cmp_lt_s_2_i64
vm.func @test_cmp_lt_s_2_i64() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2:3 = vm.const.i64 2  // 0x0000000000000002
  %i4:5 = vm.const.i64 -1  // 0xFFFFFFFFFFFFFFFF
  %i6 = vm.cmp.lt.i64.s %i4:5, %i2:3
  %i1 = vm.cmp.ne.i32 %i6, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "18446744073709551615 (ULONG_MAX) < 2"
}

vm.export @test_cmp_lt_u_0_i64
vm.func @test_cmp_lt_u_0_i64() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2:3 = vm.const.i64 -2  // 0xFFFFFFFFFFFFFFFE
  %i4:5 = vm.const.i64 2  // 0x0000000000000002
  %i6 = vm.cmp.lt.i64.u %i4:5, %i2:3
  %i1 = vm.cmp.ne.i32 %i6, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "2 < -2 (as unsigned)"
}

