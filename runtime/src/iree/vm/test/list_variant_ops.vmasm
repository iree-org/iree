vm.func @fail_uninitialized_access() -> () {
^bb0:
  %i0 = vm.const.i32.zero
  %i1 = vm.const.i32 1  // 0x00000001
  %r0 = vm.const.ref.rodata 0  // 12b
  %r1 = vm.list.alloc %i1 : !vm.list<!vm.opaque>
  vm.list.set.ref %r1, %i0, %R0
  vm.discard.refs %r1
  vm.return
}

