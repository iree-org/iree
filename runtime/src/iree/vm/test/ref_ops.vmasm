}

vm.export @test_ping_pong_swap
vm.func @test_ping_pong_swap() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 3  // 0x00000003
  %i2 = vm.const.i32 1  // 0x00000001
  %i3 = vm.const.i32.zero
  %r0 = vm.const.ref.rodata 0  // 3b
  %r1 = vm.const.ref.rodata 1  // 3b
  vm.br ^bb1()
^bb1:
  %i4 = vm.cmp.nz.ref %r0
  %i4 = vm.xor.i32 %i4, %i2
  vm.cond_br %i4, ^bb7(), ^bb2()
^bb2:
  %i4 = vm.cmp.nz.ref %r1
  %i4 = vm.xor.i32 %i4, %i2
  vm.cond_br %i4, ^bb6(), ^bb3()
^bb3:
  %i4 = vm.cmp.ne.ref %r0, %r1
  %i4 = vm.xor.i32 %i4, %i2
  vm.cond_br %i4, ^bb5(), ^bb4()
^bb4:
  %i3 = vm.add.i32 %i3, %i2
  %i4 = vm.cmp.lt.i32.s %i3, %i1
  vm.cond_br %i4, ^bb1(%r0->%r2, %R1->%r0, %R2->%r1), ^bb8()
^bb5:
  vm.discard.refs %r0, %r1
  vm.fail %i0, "x and y are different"
^bb6:
  vm.discard.refs %r0, %r1
  vm.fail %i0, "y valid in loop"
^bb7:
  vm.discard.refs %r0, %r1
  vm.fail %i0, "x valid in loop"
^bb8:
  vm.discard.refs %r0, %r1
  vm.return
}

