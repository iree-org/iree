vm.export @test_list_multiple_refs
vm.func @test_list_multiple_refs() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32.zero
  %i2 = vm.const.i32 1  // 0x00000001
  %i3 = vm.const.i32 2  // 0x00000002
  %r0 = vm.const.ref.rodata 0  // 3b
  %r1 = vm.const.ref.rodata 1  // 3b
  %r2 = vm.list.alloc %i3 : !vm.list<!vm.opaque>
  vm.list.resize %r2, %i3
  vm.list.set.ref %r2, %i1, %r0
  vm.list.set.ref %r2, %i2, %r1
  %r3 = vm.list.get.ref %r2, %i1 : !vm.buffer
  %r4 = vm.list.get.ref %r2, %i2 : !vm.buffer
  vm.discard.refs %r2
  %i1 = vm.cmp.eq.ref %r0, %r3
  vm.discard.refs %r0
  %i1 = vm.xor.i32 %i1, %i2
  vm.cond_br %i1, ^bb6(), ^bb1()
^bb1:
  %i1 = vm.cmp.eq.ref %r1, %r4
  vm.discard.refs %r1
  %i1 = vm.xor.i32 %i1, %i2
  vm.cond_br %i1, ^bb5(), ^bb2()
^bb2:
  %i1 = vm.cmp.ne.ref %r3, %r4
  vm.discard.refs %r3, %r4
  %i2 = vm.xor.i32 %i1, %i2
  vm.cond_br %i2, ^bb4(), ^bb3()
^bb3:
  vm.return
^bb4:
  vm.fail %i0, "refs are different"
^bb5:
  vm.discard.refs %r3, %r4
  vm.fail %i0, "retrieved ref_b equals set ref_b"
^bb6:
  vm.discard.refs %r1, %r3, %r4
  vm.fail %i0, "retrieved ref_a equals set ref_a"
}

