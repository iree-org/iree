^bb4:
  %i5 = vm.add.i32 %i5, %i2
  %i6 = vm.cmp.lt.i32.s %i5, %i1
  vm.cond_br %i6, ^bb4(), ^bb5()
^bb5:
  %i4 = vm.add.i32 %i4, %i2
  %i5 = vm.cmp.lt.i32.s %i4, %i1
  vm.cond_br %i5, ^bb1(), ^bb6()
^bb6:
