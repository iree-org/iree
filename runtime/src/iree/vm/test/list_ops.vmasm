vm.func @fail_out_of_bounds_read() -> () {
^bb0:
  %i0 = vm.const.i32 1  // 0x00000001
  %r0 = vm.list.alloc %i0 : !vm.list<i32>
  vm.list.resize %r0, %i0
  %i1 = vm.list.get.i32 %r0, %i0
  vm.list.set.i32 %r0, %i0, %i1
  vm.discard.refs %r0
  vm.return
}

