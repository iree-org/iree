vm.module @assignment_ops version 0
vm.type i32
vm.type i8
vm.type !vm.list<i8>

vm.export @test_select_i32
vm.func @test_select_i32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2 = vm.const.i32.zero
  %i3 = vm.select.i32 %i2 ? %i2 : %i1
  %i3 = vm.cmp.ne.i32 %i3, %i1
  vm.cond_br %i3, ^bb4(), ^bb1()
^bb1:
  %i1 = vm.select.i32 %i1 ? %i2 : %i1
  %i1 = vm.cmp.nz.i32 %i1
  vm.cond_br %i1, ^bb3(), ^bb2()
^bb2:
  vm.return
^bb3:
  vm.fail %i0, "1 ? 0 : 1 = 0"
^bb4:
  vm.fail %i0, "0 ? 0 : 1 = 1"
}

vm.export @test_select_ref
vm.func @test_select_ref() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2 = vm.const.i32.zero
  %r0 = vm.list.alloc %i2 : !vm.list<i8>
  %r1 = vm.list.alloc %i1 : !vm.list<i8>
  %r0 = vm.select.ref %i2 ? %R0 : %r1 -> !vm.list<i8>
  %i2 = vm.cmp.eq.ref %r0, %r1
  vm.discard.refs %r0, %r1
  %i1 = vm.xor.i32 %i2, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "0 ? list0 : list1 = list1"
}

vm.export @test_switch_i32
vm.func @test_switch_i32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 2  // 0x00000002
  %i2 = vm.const.i32 1  // 0x00000001
  %i3 = vm.const.i32 100  // 0x00000064
  %i4 = vm.const.i32 200  // 0x000000C8
  %i5 = vm.const.i32 300  // 0x0000012C
  %i6 = vm.const.i32.zero
  %i6 = vm.switch.i32 %i6[%i3, %i4] else %i5
  %i6 = vm.cmp.ne.i32 %i6, %i3
  vm.cond_br %i6, ^bb6(), ^bb1()
^bb1:
  %i2 = vm.switch.i32 %i2[%i3, %i4] else %i5
  %i2 = vm.cmp.ne.i32 %i2, %i4
  vm.cond_br %i2, ^bb5(), ^bb2()
^bb2:
  %i4 = vm.switch.i32 %i1[%i3, %i4] else %i5
  %i5 = vm.cmp.ne.i32 %i4, %i5
  vm.cond_br %i5, ^bb4(), ^bb3()
^bb3:
  vm.return
^bb4:
  vm.fail %i0, "index 2 (out of bounds) is default 300"
^bb5:
  vm.fail %i0, "index 1 is 200"
^bb6:
  vm.fail %i0, "index 0 is 100"
}
