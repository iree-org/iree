vm.export @test_call_variadic_yieldable_sequential
vm.func @test_call_variadic_yieldable_sequential() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 38  // 0x00000026
  %i2 = vm.const.i32 1  // 0x00000001
  %i3 = vm.const.i32 2  // 0x00000002
  %i4 = vm.const.i32 5  // 0x00000005
  %i5 = vm.const.i32 10  // 0x0000000A
  %i6 = vm.const.i32 20  // 0x00000014
  vm.call.variadic.yieldable @yieldable_test.yield_variadic_sum segments[2, 1](%i5, %i6, %i3) -> ^bb1(%i3)
^bb1:
  vm.call.variadic.yieldable @yieldable_test.yield_variadic_sum segments[2, 1](%i3, %i4, %i2) -> ^bb2(%i2)
^bb2:
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb4(), ^bb3()
^bb3:
  vm.return
^bb4:
  vm.fail %i0, "((10+20)+2)+((32+5)+1)=38"
}
