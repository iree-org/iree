^bb1:
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb3(), ^bb2()
^bb2:
  vm.return
^bb3:
  vm.fail %i0, "((50+1)+2)+1=54"
}

