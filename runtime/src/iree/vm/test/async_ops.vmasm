vm.module @async_ops version 0
vm.type i32
vm.import @yieldable_test.yield_n cconv "0ii_i"
vm.import @yieldable_test.yield_variadic_sum cconv "0CiDi_i"

vm.export @test_yield_sequence
vm.func @test_yield_sequence() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 103  // 0x00000067
  %i2 = vm.const.i32 1  // 0x00000001
  %i3 = vm.const.i32 100  // 0x00000064
  %i3 = vm.add.i32 %i3, %i2
  vm.yield ^bb1()
^bb1:
  %i3 = vm.add.i32 %i3, %i2
  vm.yield ^bb2()
^bb2:
  %i2 = vm.add.i32 %i3, %i2
  vm.yield ^bb3()
^bb3:
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb5(), ^bb4()
^bb4:
  vm.return
^bb5:
  vm.fail %i0, "100+1+1+1=103"
}

vm.export @test_yield_divergent_true
vm.func @test_yield_divergent_true() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 100  // 0x00000064
  vm.yield ^bb1()
^bb1:
  %i1 = vm.cmp.ne.i32 %i1, %i1
  vm.cond_br %i1, ^bb3(), ^bb2()
^bb2:
  vm.return
^bb3:
  vm.fail %i0, "cond=1 selects true branch"
}

vm.export @test_yield_divergent_false
vm.func @test_yield_divergent_false() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 200  // 0x000000C8
  vm.yield ^bb1()
^bb1:
  %i1 = vm.cmp.ne.i32 %i1, %i1
  vm.cond_br %i1, ^bb3(), ^bb2()
^bb2:
  vm.return
^bb3:
  vm.fail %i0, "cond=0 selects false branch"
}

vm.func @fn3(%i0: i32) -> (i32) {
^bb0:
  %i1 = vm.const.i32 1  // 0x00000001
  %i0 = vm.add.i32 %i0, %i1
  vm.yield ^bb1()
^bb1:
  %i0 = vm.add.i32 %i0, %i1
  vm.yield ^bb2()
^bb2:
  %i0 = vm.add.i32 %i0, %i1
  vm.yield ^bb3()
^bb3:
  %i1 = vm.add.i32 %i0, %i1
  vm.return %i1
}

vm.export @test_call_yieldable_internal
vm.func @test_call_yieldable_internal() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 4  // 0x00000004
  %i2 = vm.const.i32.zero
  vm.call.yieldable @async_ops:3(%i2) -> ^bb1(%i2)
^bb1:
  %i1 = vm.cmp.ne.i32 %i2, %i1
  vm.cond_br %i1, ^bb3(), ^bb2()
^bb2:
  vm.return
^bb3:
  vm.fail %i0, "0+4=4"
}

