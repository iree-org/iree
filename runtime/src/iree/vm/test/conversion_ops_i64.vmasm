vm.module @conversion_ops_i64 version 0
vm.type i32
vm.type i64

vm.export @test_trunc_i64_i32
vm.func @test_trunc_i64_i32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 -1  // 0xFFFFFFFF
  %i2:3 = vm.const.i64 9223372036854775807  // 0x7FFFFFFFFFFFFFFF
  %i4 = vm.trunc.i64.i32 %i2:3
  %i1 = vm.cmp.ne.i32 %i4, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "truncate unsigned i64 to unsigned i32"
}
