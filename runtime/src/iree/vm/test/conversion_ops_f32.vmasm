vm.module @conversion_ops_f32 version 0
vm.type f32
vm.type i32
vm.type i64

vm.export @test_bitcast_i32_f32
vm.func @test_bitcast_i32_f32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.f32 5.5
  %i2 = vm.const.i32 1085276160  // 0x40B00000
  %i3 = vm.bitcast.i32.f32 %i2
  %i2 = vm.cmp.ne.f32.o %i3, %i1
  vm.cond_br %i2, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "bitcast i32 to f32"
}

vm.export @test_bitcast_f32_i32
vm.func @test_bitcast_f32_i32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1085276160  // 0x40B00000
  %i2 = vm.const.f32 5.5
  %i3 = vm.bitcast.f32.i32 %i2
  %i1 = vm.cmp.ne.i32 %i3, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "bitcast f32 to i32"
}

vm.export @test_cast_si32_f32_int_max
vm.func @test_cast_si32_f32_int_max() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.f32 2.14748365e+09
  %i2 = vm.const.i32 2147483647  // 0x7FFFFFFF
  %i3 = vm.cast.si32.f32 %i2
  %i2 = vm.cmp.ne.f32.o %i3, %i1
  vm.cond_br %i2, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "cast signed integer to a floating-point value"
}

vm.export @test_cast_si32_f32_int_min
vm.func @test_cast_si32_f32_int_min() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.f32 -2.14748365e+09
  %i2 = vm.const.i32 -2147483648  // 0x80000000
  %i3 = vm.cast.si32.f32 %i2
  %i2 = vm.cmp.ne.f32.o %i3, %i1
  vm.cond_br %i2, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "cast signed integer to a floating-point value"
}

vm.export @test_cast_ui32_f32_int_max
vm.func @test_cast_ui32_f32_int_max() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.f32 4.2949673e+09
  %i2 = vm.const.i32 -1  // 0xFFFFFFFF
  %i3 = vm.cast.ui32.f32 %i2
  %i2 = vm.cmp.ne.f32.o %i3, %i1
  vm.cond_br %i2, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "cast unsigned integer to a floating-point value"
}

