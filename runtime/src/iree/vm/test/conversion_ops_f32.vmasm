vm.export @test_cast_f32_si64_int_max
vm.func @test_cast_f32_si64_int_max() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i2:3 = vm.const.i64 9223371487098961920  // 0x7FFFFF8000000000
  %i1 = vm.const.f32 9.22337149e+18
  %i4:5 = vm.cast.f32.si64 %i1
  %i1 = vm.cmp.ne.i64 %i4:5, %i2:3
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "cast floating-point value to a signed integer"
}

vm.export @test_cast_f32_si64_int_min
vm.func @test_cast_f32_si64_int_min() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i2:3 = vm.const.i64 1  // 0x0000000000000001
  %i4:5 = vm.const.i64 -9223372036854775807  // 0x8000000000000001
  %i1 = vm.const.f32 -9.22337204e+18
  %i6:7 = vm.cast.f32.si64 %i1
  %i2:3 = vm.sub.i64 %i4:5, %i2:3
  %i1 = vm.cmp.ne.i64 %i6:7, %i2:3
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "cast floating-point value to a signed integer"
}

