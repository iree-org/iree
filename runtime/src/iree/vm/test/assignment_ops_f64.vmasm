vm.module @assignment_ops_f64 version 0
vm.type f64
vm.type i32

vm.export @test_select_f64
vm.func @test_select_f64() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i2:3 = vm.const.f64 1
  %i4:5 = vm.const.f64.zero
  %i1 = vm.const.i32 1  // 0x00000001
  %i6 = vm.const.i32.zero
  %i8:9 = vm.select.f64 %i6 ? %i4:5 : %i2:3
  %i6 = vm.cmp.ne.f64.o %i8:9, %i2:3
  vm.cond_br %i6, ^bb4(), ^bb1()
^bb1:
  %i2:3 = vm.select.f64 %i1 ? %i4:5 : %i2:3
  %i1 = vm.cmp.ne.f64.o %i2:3, %i4:5
  vm.cond_br %i1, ^bb3(), ^bb2()
^bb2:
  vm.return
^bb3:
  vm.fail %i0, "1 ? 0.0 : 1.0 = 0.0"
^bb4:
  vm.fail %i0, "0 ? 0.0 : 1.0 = 1.0"
}

vm.export @test_switch_f64
vm.func @test_switch_f64() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 2  // 0x00000002
  %i2 = vm.const.i32 1  // 0x00000001
  %i4:5 = vm.const.f64 100
  %i6:7 = vm.const.f64 200
  %i8:9 = vm.const.f64 300
  %i3 = vm.const.i32.zero
  %i10:11 = vm.switch.f64 %i3[%i4, %i6] else %i8:9
  %i3 = vm.cmp.ne.f64.o %i10:11, %i4:5
  vm.cond_br %i3, ^bb6(), ^bb1()
^bb1:
  %i10:11 = vm.switch.f64 %i2[%i4, %i6] else %i8:9
  %i2 = vm.cmp.ne.f64.o %i10:11, %i6:7
  vm.cond_br %i2, ^bb5(), ^bb2()
^bb2:
  %i6:7 = vm.switch.f64 %i1[%i4, %i6] else %i8:9
  %i1 = vm.cmp.ne.f64.o %i6:7, %i8:9
  vm.cond_br %i1, ^bb4(), ^bb3()
^bb3:
  vm.return
^bb4:
  vm.fail %i0, "index 2 (out of bounds) is default 300"
^bb5:
  vm.fail %i0, "index 1 is 200"
^bb6:
  vm.fail %i0, "index 0 is 100"
}
