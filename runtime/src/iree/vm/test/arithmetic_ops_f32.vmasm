vm.module @arithmetic_ops_f32 version 0
vm.type f32
vm.type i32

vm.export @test_add_f32
vm.func @test_add_f32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.f32 3
  %i2 = vm.const.f32 1.5
  %i2 = vm.add.f32 %i2, %i2
  %i3 = vm.cmp.ne.f32.o %i2, %i1
  vm.cond_br %i3, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "1.5+1.5=3"
}

