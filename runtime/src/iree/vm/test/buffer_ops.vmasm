vm.export @test_hash
vm.func @test_hash() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i2:3 = vm.const.i64 8153574914611379406  // 0x7127512F72F27CCE
  %i4:5 = vm.const.i64 -4836423040314787606  // 0xBCE192DE8A85B8EA
  %i6:7 = vm.const.i64 4551675220716592091  // 0x3F2ACC7F57C29BDB
  %i8:9 = vm.const.i64 1762690195596617357  // 0x18765564CD99A68D
  %i10:11 = vm.const.i64.zero
  %i12:13 = vm.const.i64 5  // 0x0000000000000005
  %i14:15 = vm.const.i64 16  // 0x0000000000000010
  %i16:17 = vm.const.i64 25  // 0x0000000000000019
  %i18:19 = vm.const.i64 32  // 0x0000000000000020
  %r0 = vm.const.ref.rodata 12  // 32b
  %i12:13 = vm.buffer.hash %r0, %i10:11, %i12:13
  %i1 = vm.cmp.ne.i64 %i12:13, %i8:9
  vm.cond_br %i1, ^bb8(), ^bb1()
^bb1:
  %i14:15 = vm.buffer.hash %r0, %i10:11, %i14:15
  %i1 = vm.cmp.ne.i64 %i14:15, %i6:7
  vm.cond_br %i1, ^bb7(), ^bb2()
^bb2:
  %i16:17 = vm.buffer.hash %r0, %i10:11, %i16:17
  %i1 = vm.cmp.ne.i64 %i16:17, %i4:5
  vm.cond_br %i1, ^bb6(), ^bb3()
^bb3:
  %i18:19 = vm.buffer.hash %r0, %i10:11, %i18:19
  vm.discard.refs %r0
  %i1 = vm.cmp.ne.i64 %i18:19, %i2:3
  vm.cond_br %i1, ^bb5(), ^bb4()
^bb4:
  vm.return
^bb5:
  vm.fail %i0, "0-31: 0x7127512f72f27cce"
^bb6:
  vm.discard.refs %r0
  vm.fail %i0, "0-24: 0xbce192de8a85b8ea"
^bb7:
  vm.discard.refs %r0
  vm.fail %i0, "0-15: 0x3f2acc7f57c29bdb"
^bb8:
  vm.discard.refs %r0
  vm.fail %i0, "0-4: 0x18765564cd99a68d"
}
