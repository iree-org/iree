vm.export @test_clone
vm.func @test_clone() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2:3 = vm.const.i64.zero
  %i4 = vm.const.i32 16  // 0x00000010
  %i6:7 = vm.const.i64 8  // 0x0000000000000008
  %i8:9 = vm.const.i64 4  // 0x0000000000000004
  %r0 = vm.const.ref.rodata 0  // 12b
  %r1 = vm.buffer.clone %r0, %i8:9, %i6:7, %i4
  %i4 = vm.cmp.nz.ref %r1
  %i4 = vm.xor.i32 %i4, %i1
  vm.cond_br %i4, ^bb4(), ^bb1()
^bb1:
  %i4 = vm.buffer.compare %r0, %i8:9, %r1, %i2:3, %i6:7
  vm.discard.refs %r0, %r1
  %i4 = vm.cmp.nz.i32 %i4
  %i1 = vm.xor.i32 %i4, %i1
  vm.cond_br %i1, ^bb3(), ^bb2()
^bb2:
  vm.return
^bb3:
  vm.fail %i0, "buffer subspans are equal"
^bb4:
  vm.discard.refs %r0, %r1
  vm.fail %i0, "!null"
}

