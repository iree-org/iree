vm.export @test_fill_f32
vm.func @test_fill_f32() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2:3 = vm.const.i64.zero
  %i4 = vm.const.f32 42
  %i6:7 = vm.const.i64 2  // 0x0000000000000002
  %i8:9 = vm.const.i64 1  // 0x0000000000000001
  %i5 = vm.const.i32 16  // 0x00000010
  %i10:11 = vm.const.i64 16  // 0x0000000000000010
  %r0 = vm.buffer.alloc %i10:11, %i5
  %i5 = vm.cmp.nz.ref %r0
  %i5 = vm.xor.i32 %i5, %i1
  vm.cond_br %i5, ^bb4(), ^bb1()
^bb1:
  vm.buffer.fill.f32 %r0, %i8:9, %i6:7, %i4
  %r1 = vm.const.ref.rodata 4  // 16b
  %i4 = vm.buffer.compare %r1, %i2:3, %r0, %i2:3, %i10:11
  vm.discard.refs %r1, %r0
  %i4 = vm.cmp.nz.i32 %i4
  %i1 = vm.xor.i32 %i4, %i1
  vm.cond_br %i1, ^bb3(), ^bb2()
^bb2:
  vm.return
^bb3:
  vm.fail %i0, "buffer should match reference"
^bb4:
  vm.discard.refs %r0
  vm.fail %i0, "!null"
}

