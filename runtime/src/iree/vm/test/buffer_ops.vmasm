vm.module @buffer_ops version 0
vm.type f32
vm.type i32
vm.type i64
vm.type !vm.buffer
vm.rodata[0] = 010000000200000003000000
vm.rodata[1] = 64000000C80000002C010000
vm.rodata[2] = 64000000C90000002C010000
vm.rodata[3] = 02000000
vm.rodata[4] = 00000000000028420000284200000000
vm.rodata[5] = 00666600
vm.rodata[6] = 0000FECAFECA0000
vm.rodata[7] = 000000000000FFFF0000FFFF00000000
vm.rodata[8] = 0000000000000000000000000100000000000000010000000000000000000000
vm.rodata[9] = 00017F80FF
vm.rodata[10] = 00000100FF7F0080FFFF
vm.rodata[11] = 0000000001000000FFFFFF7F00000080FFFFFFFF
vm.rodata[12] = 000102030405060708090A0B0C0D0E0F101112131415161718191A1B1C1D1E1F

vm.export @test_compare
vm.func @test_compare() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2:3 = vm.const.i64.zero
  %r0 = vm.const.ref.rodata 1  // 12b
  %r1 = vm.const.ref.rodata 2  // 12b
  %i4:5 = vm.buffer.length %r0
  %i6 = vm.buffer.compare %r0, %i2:3, %r0, %i2:3, %i4:5
  %i6 = vm.cmp.nz.i32 %i6
  %i1 = vm.xor.i32 %i6, %i1
  vm.cond_br %i1, ^bb4(), ^bb1()
^bb1:
  %i1 = vm.buffer.compare %r0, %i2:3, %r1, %i2:3, %i4:5
  vm.discard.refs %r0, %r1
  %i1 = vm.cmp.nz.i32 %i1
  vm.cond_br %i1, ^bb3(), ^bb2()
^bb2:
  vm.return
^bb3:
  vm.fail %i0, "buffer a != b"
^bb4:
  vm.discard.refs %r0, %r1
  vm.fail %i0, "buffer a == a"
}

vm.export @test_compare_empty
vm.func @test_compare_empty() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2:3 = vm.const.i64 2  // 0x0000000000000002
  %i4:5 = vm.const.i64.zero
  %r0 = vm.const.ref.rodata 1  // 12b
  %r1 = vm.const.ref.rodata 2  // 12b
  vm.discard.refs %r1
  %i6 = vm.buffer.compare %r0, %i2:3, %r0, %i2:3, %i4:5
  vm.discard.refs %r0
  %i6 = vm.cmp.nz.i32 %i6
  %i1 = vm.xor.i32 %i6, %i1
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "empty buffer ranges are always equal"
}

vm.export @test_alloc
vm.func @test_alloc() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2:3 = vm.const.i64 128  // 0x0000000000000080
  %i4 = vm.const.i32 16  // 0x00000010
  %r0 = vm.buffer.alloc %i2:3, %i4
  %i4 = vm.cmp.nz.ref %r0
  %i1 = vm.xor.i32 %i4, %i1
  vm.cond_br %i1, ^bb4(), ^bb1()
^bb1:
  %i4:5 = vm.buffer.length %r0
  vm.discard.refs %r0
  %i1 = vm.cmp.ne.i64 %i4:5, %i2:3
  vm.cond_br %i1, ^bb3(), ^bb2()
^bb2:
  vm.return
^bb3:
  vm.fail %i0, "buffer length == 128"
^bb4:
  vm.discard.refs %r0
  vm.fail %i0, "!null"
}

