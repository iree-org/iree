vm.export @test_store_i8
vm.func @test_store_i8() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 255  // 0x000000FF
  %i2:3 = vm.const.i64 4  // 0x0000000000000004
  %i4 = vm.const.i32 128  // 0x00000080
  %i6:7 = vm.const.i64 3  // 0x0000000000000003
  %i5 = vm.const.i32 127  // 0x0000007F
  %i8:9 = vm.const.i64 2  // 0x0000000000000002
  %i10 = vm.const.i32 1  // 0x00000001
  %i12:13 = vm.const.i64 1  // 0x0000000000000001
  %i11 = vm.const.i32.zero
  %i14:15 = vm.const.i64.zero
  %i16 = vm.const.i32 16  // 0x00000010
  %r0 = vm.const.ref.rodata 9  // 5b
  %i18:19 = vm.buffer.length %r0
  %r1 = vm.buffer.alloc %i18:19, %i16
  vm.buffer.store.i8 %i11, %r1, %i14:15
  vm.buffer.store.i8 %i10, %r1, %i12:13
  vm.buffer.store.i8 %i5, %r1, %i8:9
  vm.buffer.store.i8 %i4, %r1, %i6:7
  vm.buffer.store.i8 %i1, %r1, %i2:3
  %i1 = vm.buffer.compare %r0, %i14:15, %r1, %i14:15, %i18:19
  vm.discard.refs %r0, %r1
  %i1 = vm.cmp.nz.i32 %i1
  %i10 = vm.xor.i32 %i1, %i10
  vm.cond_br %i10, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "source and target match"
}

