vm.export @test_copy_full
vm.func @test_copy_full() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i1 = vm.const.i32 1  // 0x00000001
  %i2:3 = vm.const.i64.zero
  %i4 = vm.const.i32 16  // 0x00000010
  %r0 = vm.const.ref.rodata 0  // 12b
  %i6:7 = vm.buffer.length %r0
  %i5 = vm.cmp.nz.ref %r0
  %i5 = vm.xor.i32 %i5, %i1
  vm.cond_br %i5, ^bb5(), ^bb1()
^bb1:
  %r1 = vm.buffer.alloc %i6:7, %i4
  %i4 = vm.cmp.nz.ref %r1
  %i4 = vm.xor.i32 %i4, %i1
  vm.cond_br %i4, ^bb6(), ^bb2()
^bb2:
  vm.buffer.copy %r0, %i2:3, %r1, %i2:3, %i6:7
  %i4 = vm.buffer.compare %r0, %i2:3, %r1, %i2:3, %i6:7
  vm.discard.refs %r0, %r1
  %i4 = vm.cmp.nz.i32 %i4
  %i1 = vm.xor.i32 %i4, %i1
  vm.cond_br %i1, ^bb4(), ^bb3()
^bb3:
  vm.return
^bb4:
  vm.fail %i0, "source and target match"
^bb5:
  vm.discard.refs %r0
  vm.br ^bb7()
^bb6:
  vm.discard.refs %r0, %r1
  vm.br ^bb7()
^bb7:
  vm.fail %i0, "!null"
}

