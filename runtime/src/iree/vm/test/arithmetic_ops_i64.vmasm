vm.export @test_div_i64s
vm.func @test_div_i64s() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i2:3 = vm.const.i64 -2  // 0xFFFFFFFFFFFFFFFE
  %i4:5 = vm.const.i64 4  // 0x0000000000000004
  %i4:5 = vm.div.i64.s %i4:5, %i2:3
