vm.module @arithmetic_ops_i64 version 0
vm.type i32
vm.type i64

vm.export @test_add_i64
vm.func @test_add_i64() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i2:3 = vm.const.i64 2  // 0x0000000000000002
  %i4:5 = vm.const.i64 1  // 0x0000000000000001
  %i4:5 = vm.add.i64 %i4:5, %i4:5
  %i1 = vm.cmp.ne.i64 %i4:5, %i2:3
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "1+1=2"
}

