vm.export @test_fma_i64
vm.func @test_fma_i64() -> () {
^bb0:
  %i0 = vm.const.i32 9  // 0x00000009
  %i2:3 = vm.const.i64 11  // 0x000000000000000B
  %i4:5 = vm.const.i64 5  // 0x0000000000000005
  %i6:7 = vm.const.i64 3  // 0x0000000000000003
