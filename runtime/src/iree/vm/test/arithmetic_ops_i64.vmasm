  %i4:5 = vm.fma.i64 %i8:9, %i6:7, %i4:5
  %i1 = vm.cmp.ne.i64 %i4:5, %i2:3
  vm.cond_br %i1, ^bb2(), ^bb1()
^bb1:
  vm.return
^bb2:
  vm.fail %i0, "2*3+5=11"
}

