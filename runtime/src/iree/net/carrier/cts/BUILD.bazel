#===------------------------------------------------------------------------===#
# Benchmark suite libraries
#===------------------------------------------------------------------------===#

# Roundtrip benchmark: send->recv latency at various message sizes.
iree_runtime_cc_library(
    name = "roundtrip_benchmark_lib",
    testonly = True,
    srcs = ["roundtrip_benchmark.cc"],
    deps = [
        "//runtime/src/iree/net/carrier/cts/util:benchmark_base",
        "//runtime/src/iree/net/carrier/cts/util:registry",
        "@com_google_benchmark//:benchmark",
    ],
    alwayslink = True,
)

# Throughput benchmark: sustained bytes/sec and IOPS at various message sizes.
iree_runtime_cc_library(
    name = "throughput_benchmark_lib",
    testonly = True,
    srcs = ["throughput_benchmark.cc"],
    deps = [
        "//runtime/src/iree/net/carrier/cts/util:benchmark_base",
        "//runtime/src/iree/net/carrier/cts/util:registry",
        "@com_google_benchmark//:benchmark",
    ],
    alwayslink = True,
)

# Latency benchmark: cold (notification) vs warm (poll) delivery latency.
iree_runtime_cc_library(
    name = "latency_benchmark_lib",
    testonly = True,
    srcs = ["latency_benchmark.cc"],
    deps = [
        "//runtime/src/iree/net/carrier/cts/util:benchmark_base",
        "//runtime/src/iree/net/carrier/cts/util:registry",
        "@com_google_benchmark//:benchmark",
    ],
    alwayslink = True,
)

# Combined library of all benchmark suites.
iree_runtime_cc_library(
    name = "all_benchmarks",
    testonly = True,
    deps = [
        ":latency_benchmark_lib",
        ":roundtrip_benchmark_lib",
        ":throughput_benchmark_lib",
    ],
)

#===------------------------------------------------------------------------===#
# Fuzz suite libraries
#===------------------------------------------------------------------------===#

# Operation-sequence fuzzer: interprets fuzz input as a sequence of carrier
# operations (send, recv, backpressure, error injection, deactivation, etc).
iree_runtime_cc_library(
    name = "carrier_fuzz_lib",
    testonly = True,
    srcs = ["carrier_fuzz.cc"],
    deps = [
        "//runtime/src/iree/async",
        "//runtime/src/iree/async:platform",
        "//runtime/src/iree/base",
        "//runtime/src/iree/net:carrier",
        "//runtime/src/iree/net/carrier/cts/util:fuzz_base",
        "//runtime/src/iree/net/carrier/cts/util:registry",
    ],
    alwayslink = True,
)
