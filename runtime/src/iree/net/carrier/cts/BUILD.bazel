# Conformance Test Suite (CTS) for carrier implementations.
#
# Test suites self-register via CTS_REGISTER_TEST_SUITE(). Backends register
# via CtsRegistry::RegisterBackend(). main.cc calls InstantiateAll() to create
# gtest parameterized test instances.

load("//build_tools/bazel:build_defs.oss.bzl", "iree_runtime_cc_library")

package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
    licenses = ["notice"],
)

#===------------------------------------------------------------------------===#
# Test suite libraries
#===------------------------------------------------------------------------===#

iree_runtime_cc_library(
    name = "lifecycle_test_lib",
    testonly = True,
    srcs = ["lifecycle_test.cc"],
    deps = [
        "//runtime/src/iree/net/carrier/cts/util:registry",
        "//runtime/src/iree/net/carrier/cts/util:test_base",
        "//runtime/src/iree/testing:gtest",
    ],
    alwayslink = True,
)

