package(default_visibility = ["//visibility:public"])

cc_library(
    name = "printf",
    srcs = ["src/printf/printf.c"],
    hdrs = ["src/printf/printf.h"],
    copts = select({
        "@bazel_tools//src/conditions:windows": [],
        "//conditions:default": [
            "-Wno-sign-conversion",
        ],
    }),
    local_defines = [
        "PRINTF_SUPPORT_WRITEBACK_SPECIFIER=0",
    ],
    strip_include_prefix = "src",
)
