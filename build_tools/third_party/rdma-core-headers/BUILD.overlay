package(default_visibility = ["//visibility:public"])

cc_library(
    name = "rdma_core_headers",
    hdrs = glob([
        "include/infiniband/*.h",
        "include/rdma/*.h",
    ]),
    include_prefix = "third_party/rdma-core-headers/",
    includes = ["include"],
)
